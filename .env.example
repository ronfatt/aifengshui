OPENAI_API_KEY=sk-your-api-key-here
OPENAI_CHAT_MODEL=gpt-5.5-2026-04-23
OPENAI_MODEL=gpt-5.5-2026-04-23
OPENAI_FALLBACK_MODEL=gpt-5.5-2026-04-23

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_APP_URL=https://www.enhancefengshui.com

# DOKU Checkout / SenangPay by DOKU
DOKU_ENV=sandbox
DOKU_CLIENT_ID=SNP-your-client-id
DOKU_SECRET_KEY=SK-your-active-secret-key
DOKU_API_KEY=doku_key_your-api-key
DOKU_CURRENCY=MYR
# Use "major" when DOKU expects RM29 as 29. Use "minor" only if your DOKU channel expects RM29 as 2900.
DOKU_AMOUNT_UNIT=major
# Optional override for production or custom endpoint.
# DOKU_BASE_URL=https://api.doku.com

# Legacy only. Keep these only if old SenangPay callback orders still exist.
# SENANGPAY_ENV=sandbox
# SENANGPAY_MERCHANT_ID=your-senangpay-merchant-id
# SENANGPAY_SECRET_KEY=your-senangpay-secret-key
# SENANGPAY_BASE_URL=https://app.senangpay.my
